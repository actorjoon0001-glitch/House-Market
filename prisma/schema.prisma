generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  USER
  OWNER
  ARCHITECT
  SUPPLIER
  ADMIN
}

enum CompanyCategory {
  ARCHITECT
  CONTRACTOR
  MATERIAL
  INTERIOR
  ETC
}

enum ListingType {
  USED
  REQUEST
}

enum ListingStatus {
  ACTIVE
  RESERVED
  SOLD
  CLOSED
}

enum ProjectStatus {
  DRAFT
  DESIGN_READY
  QUOTING
  CONTRACTED
  COMPLETED
}

enum QuoteStatus {
  PENDING
  SUBMITTED
  ACCEPTED
  REJECTED
}

model User {
  id           String    @id @default(cuid())
  phone        String?   @unique
  email        String?   @unique
  name         String?
  avatarUrl    String?
  role         UserRole  @default(USER)
  neighborhood String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  company  Company?
  listings Listing[]
  projects Project[]
  sentMessages     Message[] @relation("Sent")
  receivedMessages Message[] @relation("Received")
}

model Company {
  id          String          @id @default(cuid())
  ownerId     String          @unique
  owner       User            @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  name        String
  category    CompanyCategory
  description String?
  bizNumber   String?
  phone       String?
  address     String
  lat         Float
  lng         Float
  verified    Boolean         @default(false)
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  quotes Quote[]

  @@index([category])
  @@index([lat, lng])
}

model Listing {
  id        String        @id @default(cuid())
  authorId  String
  author    User          @relation(fields: [authorId], references: [id], onDelete: Cascade)
  type      ListingType   @default(USED)
  title     String
  body      String
  priceWon  Int?
  status    ListingStatus @default(ACTIVE)
  address   String?
  lat       Float?
  lng       Float?
  images    String[]
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  @@index([type, status])
  @@index([lat, lng])
}

model Message {
  id         String   @id @default(cuid())
  fromId     String
  toId       String
  body       String
  read       Boolean  @default(false)
  createdAt  DateTime @default(now())

  from User @relation("Sent", fields: [fromId], references: [id], onDelete: Cascade)
  to   User @relation("Received", fields: [toId], references: [id], onDelete: Cascade)

  @@index([fromId])
  @@index([toId])
}

/// 건축주가 시작하는 집 짓기 프로젝트.
/// requirements: 사용자가 입력한 요구사항(평수/방/스타일/예산 등)
/// floorPlan: AI가 생성한 평면도 JSON (rooms[{id,name,x,y,w,h}], walls[], totalAreaM2)
model Project {
  id           String        @id @default(cuid())
  ownerId      String
  owner        User          @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  title        String
  status       ProjectStatus @default(DRAFT)
  address      String?
  lat          Float?
  lng          Float?
  requirements Json
  floorPlan    Json?
  model3dUrl   String?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  quotes Quote[]

  @@index([ownerId])
  @@index([status])
}

model Quote {
  id           String      @id @default(cuid())
  projectId    String
  project      Project     @relation(fields: [projectId], references: [id], onDelete: Cascade)
  companyId    String
  company      Company     @relation(fields: [companyId], references: [id], onDelete: Cascade)
  status       QuoteStatus @default(PENDING)
  totalWon     Int?
  breakdown    Json?
  leadTimeDays Int?
  note         String?
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  @@unique([projectId, companyId])
  @@index([status])
}
