generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  USER
  OWNER
  ARCHITECT
  SUPPLIER
  ADMIN
}

enum CompanyCategory {
  ARCHITECT
  CONTRACTOR
  MATERIAL
  INTERIOR
  ETC
}

enum BuildSpecialty {
  STAY_REST_HOUSE   // 체류형 쉼터
  MOBILE_HOUSE      // 이동식 주택
  COUNTRY_HOUSE     // 전원주택
  PASSIVE_HOUSE     // 패시브하우스
  REMODEL           // 리모델링
}

enum VerifiedStatus {
  SAMPLE
  PUBLIC      // 공개 자료 기반 (동의 없음)
  PENDING     // 입점 신청 검토 중
  VERIFIED    // 동의 + 사업자 확인 완료
}

enum DataSource {
  SAMPLE
  PUBLIC
  USER_SUBMITTED
}

enum ConsultationStatus {
  REQUESTED
  READ
  REPLIED
  CLOSED
}

enum ConsultationSenderRole {
  USER
  COMPANY
}

enum NotificationType {
  CONSULTATION_REPLIED
  CONSULTATION_READ
  SYSTEM
}

enum ListingType {
  USED
  REQUEST
}

enum ListingStatus {
  ACTIVE
  RESERVED
  SOLD
  CLOSED
}

enum ProjectStatus {
  DRAFT
  DESIGN_READY
  QUOTING
  CONTRACTED
  COMPLETED
}

enum QuoteStatus {
  PENDING
  SUBMITTED
  ACCEPTED
  REJECTED
}

model User {
  id           String    @id @default(cuid())
  phone        String?   @unique
  email        String?   @unique
  name         String?
  avatarUrl    String?
  role         UserRole  @default(USER)
  neighborhood String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  company  Company?
  listings Listing[]
  projects Project[]
  consultations    ConsultationRequest[] @relation("UserConsultations")
  consultationMsgs ConsultationMessage[] @relation("UserConsultMsgs")
  reviews          ConsultationReview[]
  favorites        FavoriteCompany[]
  notifications    Notification[]
  sentMessages     Message[] @relation("Sent")
  receivedMessages Message[] @relation("Received")
}

model Company {
  id          String           @id @default(cuid())
  ownerId     String?          @unique
  owner       User?            @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  name        String
  category    CompanyCategory
  specialties BuildSpecialty[]
  description String?
  bizNumber   String?
  phone       String?
  address     String
  region      String?
  lat         Float
  lng         Float
  /// 핵심 표시 정책 — 클라이언트는 verifiedStatus + contactPublic만 보고 노출 결정.
  verifiedStatus         VerifiedStatus @default(SAMPLE)
  dataSource             DataSource     @default(SAMPLE)
  /// 동의 없는 공개 자료 기반 등재 여부
  isListedWithoutConsent Boolean        @default(false)
  /// 본인 동의를 받았는지
  consentGiven           Boolean        @default(false)
  /// 연락처 공개 동의 (verifiedStatus=VERIFIED 일 때만 의미 있음)
  contactPublic          Boolean        @default(false)
  isDemo                 Boolean        @default(false)
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  quotes           Quote[]
  removalRequests  CompanyRemovalRequest[]
  consultations    ConsultationRequest[]
  reviews          ConsultationReview[]
  favoritedBy      FavoriteCompany[]

  @@index([category])
  @@index([lat, lng])
  @@index([verifiedStatus])
}

/// 정보 수정·삭제 요청. 처리 후 Company.verifiedStatus를 PUBLIC→삭제 또는 정정.
model CompanyRemovalRequest {
  id           String   @id @default(cuid())
  companyId    String
  company      Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  requesterName String
  requesterPhone String?
  requesterEmail String?
  reason       String
  resolved     Boolean  @default(false)
  createdAt    DateTime @default(now())

  @@index([companyId])
  @@index([resolved])
}

/// 사용자가 입점 업체에 보낸 상담 요청.
/// 계약·견적 확정이 아니며, 양 측의 대화 컨테이너 역할.
model ConsultationRequest {
  id           String              @id @default(cuid())
  userId       String
  user         User                @relation("UserConsultations", fields: [userId], references: [id], onDelete: Cascade)
  companyId    String
  company      Company             @relation(fields: [companyId], references: [id], onDelete: Cascade)
  projectId    String?
  project      Project?            @relation(fields: [projectId], references: [id], onDelete: SetNull)
  title        String
  message      String
  budgetWon    Int?
  desiredArea  String?
  status       ConsultationStatus  @default(REQUESTED)
  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @updatedAt

  messages ConsultationMessage[]
  review   ConsultationReview?

  @@index([userId])
  @@index([companyId])
  @@index([status])
}

model ConsultationMessage {
  id                     String                 @id @default(cuid())
  consultationRequestId  String
  request                ConsultationRequest    @relation(fields: [consultationRequestId], references: [id], onDelete: Cascade)
  senderId               String
  senderRole             ConsultationSenderRole
  body                   String
  readAt                 DateTime?
  createdAt              DateTime               @default(now())

  sender User @relation("UserConsultMsgs", fields: [senderId], references: [id], onDelete: Cascade)

  @@index([consultationRequestId])
}

/// 상담 종료 후 사용자가 작성하는 후기.
/// 상담당 1개 (unique).
model ConsultationReview {
  id                    String              @id @default(cuid())
  consultationRequestId String              @unique
  request               ConsultationRequest @relation(fields: [consultationRequestId], references: [id], onDelete: Cascade)
  userId                String
  user                  User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  companyId             String
  company               Company             @relation(fields: [companyId], references: [id], onDelete: Cascade)
  /// 1-5
  rating                Int
  body                  String?
  createdAt             DateTime            @default(now())

  @@index([companyId])
  @@index([userId])
}

model FavoriteCompany {
  id        String  @id @default(cuid())
  userId    String
  user      User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  companyId String
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([userId, companyId])
  @@index([userId])
}

model Notification {
  id        String           @id @default(cuid())
  userId    String
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      NotificationType
  title     String
  body      String
  /// /consultations/[id] 같은 라우트
  link      String?
  readAt    DateTime?
  createdAt DateTime         @default(now())

  @@index([userId, readAt])
}

model Listing {
  id        String        @id @default(cuid())
  authorId  String
  author    User          @relation(fields: [authorId], references: [id], onDelete: Cascade)
  type      ListingType   @default(USED)
  title     String
  body      String
  priceWon  Int?
  status    ListingStatus @default(ACTIVE)
  address   String?
  lat       Float?
  lng       Float?
  images    String[]
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  @@index([type, status])
  @@index([lat, lng])
}

model Message {
  id         String   @id @default(cuid())
  fromId     String
  toId       String
  body       String
  read       Boolean  @default(false)
  createdAt  DateTime @default(now())

  from User @relation("Sent", fields: [fromId], references: [id], onDelete: Cascade)
  to   User @relation("Received", fields: [toId], references: [id], onDelete: Cascade)

  @@index([fromId])
  @@index([toId])
}

/// 건축주가 시작하는 집 짓기 프로젝트.
/// requirements: 사용자가 입력한 요구사항(평수/방/스타일/예산 등)
/// floorPlan: AI가 생성한 평면도 JSON (rooms[{id,name,x,y,w,h}], walls[], totalAreaM2)
model Project {
  id           String        @id @default(cuid())
  ownerId      String
  owner        User          @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  title        String
  status       ProjectStatus @default(DRAFT)
  address      String?
  lat          Float?
  lng          Float?
  requirements Json
  floorPlan    Json?
  model3dUrl   String?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  quotes        Quote[]
  consultations ConsultationRequest[]

  @@index([ownerId])
  @@index([status])
}

model Quote {
  id           String      @id @default(cuid())
  projectId    String
  project      Project     @relation(fields: [projectId], references: [id], onDelete: Cascade)
  companyId    String
  company      Company     @relation(fields: [companyId], references: [id], onDelete: Cascade)
  status       QuoteStatus @default(PENDING)
  totalWon     Int?
  breakdown    Json?
  leadTimeDays Int?
  note         String?
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  @@unique([projectId, companyId])
  @@index([status])
}
