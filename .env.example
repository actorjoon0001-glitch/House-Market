# 카카오맵 JavaScript 키 (https://developers.kakao.com)
NEXT_PUBLIC_KAKAO_MAP_KEY=

# Anthropic Claude API 키 (https://console.anthropic.com)
# 비어있으면 AI 설계는 mock 응답으로 동작합니다.
ANTHROPIC_API_KEY=

# Database
DATABASE_URL="postgresql://user:password@localhost:5432/housemarket?schema=public"

# NextAuth (추후 사용)
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=
